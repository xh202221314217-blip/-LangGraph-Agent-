# Core LLM
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Vision model
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=

# Ollama fallback
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5
OLLAMA_REASON_MODEL=qwen2.5
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_AGENT_MODEL=qwen2.5
CHAT_SERVICE=deepseek
REASON_SERVICE=deepseek
AGENT_SERVICE=deepseek

# Search
SERPAPI_KEY=
SEARCH_RESULT_COUNT=3

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=deepseek_agent

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_EXPIRE=3600
REDIS_CACHE_THRESHOLD=0.8

# Security
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# General embeddings
EMBEDDING_TYPE=openai
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BATCH_SIZE=8
EMBEDDING_THRESHOLD=0.90
OPENAI_API_KEY=
DASHSCOPE_API_KEY=

# Runtime knowledge retrieval switch
USE_GRAPHRAG=True

# GraphRAG workspace LLM and embedding
GRAPHRAG_API_KEY=
GRAPHRAG_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
GRAPHRAG_MODEL_NAME=qwen-plus
GRAPHRAG_EMBEDDING_API_KEY=
GRAPHRAG_EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
GRAPHRAG_EMBEDDING_MODEL_NAME=text-embedding-v3

# GraphRAG CLI wrapper
GRAPHRAG_CLI_PATH=../.venv/bin/graphrag
GRAPHRAG_CLI_WORKSPACE_ROOT=app/graphrag_workspaces/ragtest
GRAPHRAG_CLI_DEFAULT_METHOD=local
GRAPHRAG_CLI_TIMEOUT_SECONDS=180

# Milvus hybrid RAG
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION_NAME=t_collection01
MILVUS_DENSE_DIMENSION=1024
MILVUS_TEXT_MAX_LENGTH=6000
MILVUS_CONSISTENCY_LEVEL=Strong
MILVUS_SEARCH_TOP_K=4
MILVUS_SEARCH_SCORE_THRESHOLD=0.0
MILVUS_RRF_K=100
MILVUS_FILTER_CATEGORY=content

# Milvus dense embedding
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
RAG_EMBEDDING_DEVICE=cpu
RAG_EMBEDDING_NORMALIZE=True
RAG_OPENAI_EMBEDDING_API_KEY=
RAG_OPENAI_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RAG_OPENAI_EMBEDDING_MODEL=text-embedding-v3

# Legacy only, not required by the active GraphRAG + Milvus path
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
